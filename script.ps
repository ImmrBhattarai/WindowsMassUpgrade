#Requires -RunAsAdministrator
#Requires -Version 5.1

# ==============================================================================
# WINDOWS 11 25H2 ENTERPRISE IN-PLACE UPGRADE SCRIPT v6.0 (FINAL)
# ==============================================================================
#
# CONFIRMED ENVIRONMENT (do not change assumptions below):
#   - Windows 11 25H2 media source   : SMB share (see $NetworkSource below)
#   - setup.exe SHA256               : 72A0BCAC2D4DE630AD094BFC312BD4431AA5C286C683DE7E0650C1675E5FC7C5
#   - Reboot behavior                : NO forced reboot (/NoReboot)
#   - Edition handling               : Auto-detected via DISM, /ImageIndex selected automatically
#   - Activation handling            : Audit-only, non-destructive, no key injection
#   - Deployment method              : GPO Computer Scheduled Task running as SYSTEM
#   - Data preservation              : /Auto Upgrade — keeps ALL files, apps, settings
#   - Rollback on failure            : Automatic (Windows.old created by setup.exe itself)
#
# DATA PRESERVATION GUARANTEE:
#   /Auto Upgrade  = programmatic equivalent of selecting
#                   "Keep personal files, apps, and Windows settings" in setup GUI.
#                   This flag must NEVER be removed or changed.
#   /NoReboot      = upgrade stages silently; reboot is NEVER forced on users.
#                   When user restarts at their own will, Windows 11 completes.
#
# ==============================================================================
# CONFIGURATION — EDIT ONLY THIS BLOCK
# ==============================================================================

# DASHBOARD WEBHOOK (Live Internet Dashboard via Microsoft Teams)
$WebhookURI        = "https://webhookbot.c-toss.com/api/bot/webhooks/XYZABC123"
#Change this url based on the UL generated in the Webhook App inside your teams channel.

# UNC path to the folder containing setup.exe
$NetworkSource     = "\\FILESRVCHDC\common\Personal\XYZ\windows Upgrade\USB Drive 25H2"

# Central log collection folder on network share
$NetworkLogDir     = "\\FILESRVCHDC\common\Personal\XYZ\windows Upgrade\Logs"

# Confirmed SHA256 of your specific setup.exe
$ExpectedSHA256    = "72A0BCAC2D4DE630AD094BFC312BD4431AA5C286C683DE7E0650C1675E5FC7C5"

# Local staging directories — safe enterprise path, not Temp
$OrgUpgradeDir     = "C:\ProgramData\OrgUpgrade"
$LocalTarget       = "$OrgUpgradeDir\Win11Media"
$LogDir            = "$OrgUpgradeDir\Logs"
$StateFile         = "$OrgUpgradeDir\UpgradeState.json"

# Minimum free space on C: before upgrade is allowed to proceed.
$RequiredFreeBytes = [int64](35GB)

# ==============================================================================
# DO NOT EDIT BELOW THIS LINE
# ==============================================================================

# Suppress PowerShell progress bars for SYSTEM execution speed
$ProgressPreference = "SilentlyContinue"
$ErrorActionPreference = "Continue"

$SystemDrive = $env:SystemDrive
$MachineName = $env:COMPUTERNAME

# ==============================================================================
# STEP 0A: 32-BIT PROCESS GUARD
# Self-relaunch as 64-bit before doing anything else.
# ==============================================================================
if ([Environment]::Is64BitOperatingSystem -and (-not [Environment]::Is64BitProcess)) {
    $ps64 = Join-Path $env:WINDIR "Sysnative\WindowsPowerShell\v1.0\powershell.exe"
    if (Test-Path -LiteralPath $ps64) {
        & $ps64 -NoProfile -ExecutionPolicy Bypass -File $PSCommandPath
        exit $LASTEXITCODE
    }
}

# ==============================================================================
# STEP 0B: LOGGING & WEBHOOK INFRASTRUCTURE
# ==============================================================================
$LogFile = "$LogDir\Win11Upgrade_${MachineName}_$(Get-Date -Format 'yyyyMMdd_HHmmss').log"

function Send-Webhook {
    param([string]$Stage, [string]$Message, [string]$Status = "INFO")
    if ($WebhookURI -eq "REPLACE_WITH_YOUR_TEAMS_WEBHOOK_URL_HERE") { return }
    
    $color = if ($Status -eq "ERROR") { "FF0000" } elseif ($Status -eq "SUCCESS") { "00FF00" } else { "0076D7" }
    
    $body = @{
        "@type"      = "MessageCard"
        "@context"   = "http://schema.org/extensions"
        "themeColor" = $color
        "summary"    = "Upgrade Status: $MachineName"
        "sections"   = @(
            @{
                "activityTitle"    = "Upgrade Update: $MachineName"
                "activitySubtitle" = "Stage: $Stage"
                "text"             = "**Message:** $Message"
                "facts"            = @(@{ "name" = "Time"; "value" = (Get-Date).ToString() })
            }
        )
    } | ConvertTo-Json -Depth 5

    try {
        Invoke-RestMethod -Uri $WebhookURI -Method Post -Body $body -ContentType "application/json" -TimeoutSec 5 -ErrorAction SilentlyContinue | Out-Null
    } catch {}
}

function Write-Log {
    param([string]$Level = "INFO", [string]$Message)
    $ts   = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $line = "[$ts][$MachineName][$Level] $Message"
    Write-Output $line

    if (-not (Test-Path $LogDir -ErrorAction SilentlyContinue)) {
        try { New-Item -ItemType Directory -Path $LogDir -Force -ErrorAction Stop | Out-Null } catch {}
    }
    Add-Content -Path $LogFile -Value $line -ErrorAction SilentlyContinue
}

function Exit-WithLog {
    param([int]$Code, [string]$Reason, [bool]$TriggerCleanup = $false)
    Write-Log -Level "EXIT" -Message "ExitCode=$Code | $Reason"
    
    $statusType = if ($Code -eq 0) { "SUCCESS" } else { "ERROR" }
    Send-Webhook -Stage "EXIT" -Message "ExitCode=$Code | $Reason" -Status $statusType

    if (Test-Path -LiteralPath $NetworkLogDir -ErrorAction SilentlyContinue) {
        Copy-Item -Path $LogFile -Destination $NetworkLogDir -Force -ErrorAction SilentlyContinue
    }

    # Execute Ghost Cleanup if requested (delayed by 10 seconds to allow PowerShell to safely close locks)
    if ($TriggerCleanup) {
        $cmdArgs = "/c timeout /t 10 /nobreak > NUL & rmdir /s /q `"$OrgUpgradeDir`""
        Start-Process cmd.exe -ArgumentList $cmdArgs -WindowStyle Hidden
    }

    Exit $Code
}

# ==============================================================================
# STEP 0C: STATE MACHINE (RESUMABILITY)
# Tracks which phases have completed across runs and script interruptions.
# ==============================================================================
function Read-State {
    $defaultState = @{ Stage = "INIT"; MachineName = $MachineName }
    if (-not (Test-Path -LiteralPath $StateFile -ErrorAction SilentlyContinue)) { return $defaultState }
    try {
        $raw = Get-Content -LiteralPath $StateFile -Raw -Encoding UTF8 -ErrorAction Stop
        if ([string]::IsNullOrWhiteSpace($raw)) { return $defaultState }
        $obj   = $raw | ConvertFrom-Json -ErrorAction Stop
        $table = @{}
        foreach ($prop in $obj.PSObject.Properties) { $table[$prop.Name] = $prop.Value }
        return $table
    } catch {
        return $defaultState
    }
}

function Write-State {
    param([hashtable]$State)
    try {
        $State | ConvertTo-Json -Depth 4 | Set-Content -LiteralPath $StateFile -Encoding UTF8 -Force -ErrorAction Stop
        Send-Webhook -Stage $State['Stage'] -Message "Transitioned to $($State['Stage'])" -Status "INFO"
    } catch {
        Write-Log "WARN" "Could not write state file (non-fatal): $_"
    }
}

function Get-HexCode {
    param([int]$Code)
    return ("0x{0:X8}" -f [uint32]$Code)
}

# ==============================================================================
# SCRIPT START
# ==============================================================================
Write-Log "INFO" "Windows 11 25H2 Upgrade Script v6.0 — START"
$state = Read-State
Send-Webhook -Stage $state['Stage'] -Message "Script executed. Current known state: $($state['Stage'])"

# ==============================================================================
# SECTION 1: IDEMPOTENCY — Already on Windows 11?
# ==============================================================================
try {
    $osInfo  = Get-CimInstance -ClassName Win32_OperatingSystem -ErrorAction Stop
    $osBuild = [System.Environment]::OSVersion.Version.Build
    if ($osBuild -ge 22000) {
        Exit-WithLog 0 "Machine is already on Windows 11. Nothing to do." $true
    }
    if ($osInfo.Caption -notlike "*Windows 10*") {
        Exit-WithLog 1 "Unexpected OS. Script only upgrades Windows 10."
    }
} catch {
    Exit-WithLog 1 "Cannot query OS via CIM: $_"
}

# ==============================================================================
# SECTION 2: ARCHITECTURE CHECK
# ==============================================================================
if (-not [System.Environment]::Is64BitOperatingSystem) {
    Exit-WithLog 2 "32-bit OS detected. Windows 11 requires 64-bit."
}

# ==============================================================================
# SECTION 3: SETUP PROCESS COLLISION GUARD
# ==============================================================================
$runningSetup = Get-Process -Name "setup", "SetupHost", "SetupPrep" -ErrorAction SilentlyContinue
if ($runningSetup) {
    Exit-WithLog 0 "Windows Setup already running. Exiting to prevent corruption."
}

# ==============================================================================
# SECTION 4: DISK SPACE VALIDATION
# ==============================================================================
try {
    $cDisk  = Get-CimInstance -ClassName Win32_LogicalDisk -Filter "DeviceID='$SystemDrive'" -ErrorAction Stop
    if ([int64]$cDisk.FreeSpace -lt $RequiredFreeBytes) {
        Exit-WithLog 10 "INSUFFICIENT SPACE on $SystemDrive."
    }
} catch {
    Exit-WithLog 10 "Cannot query disk space: $_"
}

$useTempDrive = $false
try {
    $dDisk = Get-CimInstance -ClassName Win32_LogicalDisk -Filter "DeviceID='D:'" -ErrorAction SilentlyContinue
    if ($dDisk -and ([int64]$cDisk.FreeSpace -lt [int64](40GB)) -and ([int64]$dDisk.FreeSpace -gt [int64](25GB))) {
        $useTempDrive = $true
        Write-Log "INFO" "D: will be used as /TempDrive to relieve pressure on $SystemDrive."
    }
} catch {}

# ==============================================================================
# SECTION 5: PENDING REBOOT CHECK
# ==============================================================================
try {
    $cbsKey     = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Component Based Servicing"
    $cbsPending = (Get-ItemProperty -Path $cbsKey -Name "RebootPending" -ErrorAction SilentlyContinue).RebootPending
    
    $wuKey     = "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\WindowsUpdate\Auto Update\RebootRequired"
    $wuPending = Test-Path -Path $wuKey -ErrorAction SilentlyContinue
    
    $smKey  = "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager"
    $pfro   = (Get-ItemProperty -Path $smKey -Name "PendingFileRenameOperations" -ErrorAction SilentlyContinue).PendingFileRenameOperations
    $pfroHasPending = ($null -ne $pfro -and $pfro.Count -gt 0)

    if ($cbsPending -or $wuPending -or $pfroHasPending) {
        Exit-WithLog 20 "Pending reboot detected on $MachineName. Upgrade deferred."
    }
} catch {}

# ==============================================================================
# SECTION 6: BITLOCKER & ACTIVATION AUDITS
# ==============================================================================
try {
    $blVol = Get-BitLockerVolume -MountPoint $SystemDrive -ErrorAction SilentlyContinue
    if ($blVol) {
        Write-Log "INFO" "BitLocker on $SystemDrive : Protection=$($blVol.ProtectionStatus) | Volume=$($blVol.VolumeStatus)"
    }
} catch {}

try {
    $winAppID   = "55c92734-d682-4d71-983e-d6ef31105c65"
    $licProduct = Get-CimInstance -Namespace "root\CIMV2\Applications\WindowsLicensing" -ClassName SoftwareLicensingProduct -ErrorAction Stop | Where-Object { $_.PartialProductKey -and $_.ApplicationID -eq $winAppID } | Select-Object -First 1
    if ($licProduct) {
        Write-Log "INFO" "Activation: $($licProduct.LicenseStatus)"
    }
} catch {}

# ==============================================================================
# SECTION 7: ALREADY-STAGED GUARD
# ==============================================================================
$windowsBTPath = "$SystemDrive\`$Windows.~BT"
if ($state['Stage'] -eq "UPGRADE_STAGED" -and (Test-Path -LiteralPath $windowsBTPath -ErrorAction SilentlyContinue)) {
    Exit-WithLog 0 "Upgrade already staged. Awaiting user-initiated reboot." $true
}

# ==============================================================================
# SECTION 8: NETWORK SOURCE VALIDATION
# ==============================================================================
if (-not (Test-Path -LiteralPath $NetworkSource -ErrorAction SilentlyContinue)) {
    Exit-WithLog 30 "Network source NOT reachable."
}

$networkSetupExe = Join-Path $NetworkSource "setup.exe"
if (-not (Test-Path -LiteralPath $networkSetupExe -ErrorAction SilentlyContinue)) {
    Exit-WithLog 31 "setup.exe NOT found at share root."
}

$networkSetupItem = Get-Item -LiteralPath $networkSetupExe -ErrorAction SilentlyContinue
$networkSetupSize = if ($networkSetupItem) { $networkSetupItem.Length } else { 0 }

# ==============================================================================
# SECTION 9: LOCAL STAGING DIRECTORY & COPY CHECK
# ==============================================================================
try {
    New-Item -ItemType Directory -Path $LocalTarget -Force -ErrorAction Stop | Out-Null
} catch {
    Exit-WithLog 32 "Cannot create staging directory: $_"
}

$needsCopy      = $true
$localSetupExe  = Join-Path $LocalTarget "setup.exe"

if ($state['Stage'] -notin @("INIT", "COPY_FAILED") -and (Test-Path -LiteralPath $localSetupExe -ErrorAction SilentlyContinue)) {
    $localSetupItem = Get-Item -LiteralPath $localSetupExe -ErrorAction SilentlyContinue
    $localSetupSize = if ($localSetupItem) { $localSetupItem.Length } else { 0 }

    if ($localSetupSize -eq $networkSetupSize -and $localSetupSize -gt 1MB) {
        Write-Log "INFO" "Local copy matches source size. Skipping re-copy."
        $needsCopy = $false
    }
}

# ==============================================================================
# SECTION 10: RESILIENT MEDIA COPY VIA ROBOCOPY
# ==============================================================================
if ($needsCopy) {
    Write-Log "INFO" "Copying media from network to local staging..."
    Send-Webhook -Stage "COPY_STARTED" -Message "Pulling media from network share"
    
    $roboArgs = @(
        "`"$NetworkSource`"", "`"$LocalTarget`"", "/E", "/Z", "/R:5", "/W:15", "/MT:4", "/NP", "/NJH", "/NJS", "/NFL", "/NDL", "/LOG+:`"$LogFile`""
    )

    try {
        $roboProcess = Start-Process -FilePath "robocopy.exe" -ArgumentList $roboArgs -Wait -PassThru -NoNewWindow -ErrorAction Stop

        if ($roboProcess.ExitCode -ge 8) {
            $state['Stage'] = "COPY_FAILED"
            Write-State -State $state
            Exit-WithLog 33 "Robocopy FAILED (exit $($roboProcess.ExitCode))."
        }

        $state['Stage']    = "COPIED"
        $state['CopiedAt'] = (Get-Date -Format "o")
        Write-State -State $state
    } catch {
        $state['Stage'] = "COPY_FAILED"
        Write-State -State $state
        Exit-WithLog 33 "Robocopy could not launch: $_"
    }
}

# ==============================================================================
# SECTION 11: POST-COPY INTEGRITY VALIDATION (4 LAYERS)
# ==============================================================================
Write-Log "INFO" "Running post-copy integrity validation (4 layers)..."

if (-not (Test-Path -LiteralPath $localSetupExe -ErrorAction SilentlyContinue)) {
    Exit-WithLog 34 "INTEGRITY FAIL Layer 1: setup.exe missing from local staging."
}

$finalItem = Get-Item -LiteralPath $localSetupExe -ErrorAction SilentlyContinue
$finalSize = if ($finalItem) { $finalItem.Length } else { 0 }
if ($finalSize -ne $networkSetupSize) {
    Exit-WithLog 35 "INTEGRITY FAIL Layer 2: Size mismatch."
}

try {
    $sig         = Get-AuthenticodeSignature -FilePath $localSetupExe -ErrorAction Stop
    $sigSubject  = if ($sig.SignerCertificate) { $sig.SignerCertificate.Subject } else { "NoSigner" }
    $isMicrosoft = ($sigSubject -match "Microsoft")

    if (-not (($sig.Status -eq "Valid" -or $sig.Status -eq "UnknownError") -and $isMicrosoft)) {
        Exit-WithLog 36 "INTEGRITY FAIL Layer 3: Invalid signature or non-Microsoft signer."
    }
} catch {
    Exit-WithLog 36 "Cannot verify Authenticode signature: $_"
}

Write-Log "INFO" "Calculating SHA256 hash of local setup.exe..."
$localHash = (Get-FileHash -Path $localSetupExe -Algorithm SHA256 -ErrorAction Stop).Hash
if ($localHash -ne $ExpectedSHA256) {
    Exit-WithLog 37 "INTEGRITY FAIL Layer 4: Hash mismatch. Expected: $ExpectedSHA256 | Actual: $localHash"
}
Write-Log "INFO" "All 4 integrity layers passed successfully."

# ==============================================================================
# SECTION 12: EXECUTE SETUP.EXE WITH LIVE DASHBOARD POLLING
# ==============================================================================
Write-Log "INFO" "Launching Windows 11 Setup silently..."

$setupArgs = @(
    "/Auto Upgrade",           # Keep files, apps, and settings
    "/Quiet",                  # No UI, fully background
    "/NoReboot",               # Do NOT force a reboot; wait for user
    "/DynamicUpdate Disable",  # Don't download updates during setup (saves bandwidth/time)
    "/ShowOOBE None",          # Skip the "Welcome to Windows" privacy toggles post-reboot
    "/Telemetry Disable",      # Enterprise privacy
    "/BitLocker AlwaysSuspend" # Safely handle BitLocker
)
if ($useTempDrive) { $setupArgs += "/TempDrive D:" }

try {
    $state['Stage'] = "UPGRADE_LAUNCHED"
    Write-State -State $state

    $setupProcess = Start-Process -FilePath $localSetupExe -ArgumentList $setupArgs -PassThru -NoNewWindow -ErrorAction Stop
    $startTime = Get-Date

    # Live Dashboard Heartbeat Loop
    while (-not $setupProcess.HasExited) {
        $uptime = (Get-Date) - $startTime
        Write-Log "INFO" "Setup is running. Elapsed time: $($uptime.Minutes)m $($uptime.Seconds)s..."
        Send-Webhook -Stage "UPGRADE_RUNNING" -Message "Active execution. Elapsed time: $($uptime.Minutes)m" -Status "IN_PROGRESS"
        
        Start-Sleep -Seconds 180
    }

    $exitCode = $setupProcess.ExitCode
    $hexExit = Get-HexCode $exitCode
    Write-Log "INFO" "Setup.exe finished: $exitCode ($hexExit)"

    if ($exitCode -eq 0) {
        $state['Stage'] = "UPGRADE_STAGED"
        Write-State -State $state
        Write-Log "INFO" "Self-Destruct sequence armed. Cleaning traces upon exit."
        
        Exit-WithLog 0 "Upgrade successfully staged in background. Awaiting user reboot. Traces removed." $true
    } else {
        $state['Stage'] = "UPGRADE_FAILED"
        Write-State -State $state
        Exit-WithLog $exitCode "Setup.exe failed. Review C:\`$Windows.~BT\Sources\Panther\setupact.log."
    }
} catch {
    Exit-WithLog 50 "Failed to launch setup.exe: $_"
}
